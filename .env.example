# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1

# PostgreSQL (pgvector image)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_password
POSTGRES_DB=rag_enterprise
DATABASE_URL=postgresql+asyncpg://rag:rag_dev_password@localhost:5432/rag_enterprise

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Local upload binary storage (RC1.6)
FILE_STORAGE_ROOT=storage/uploads

# Frontend (Vite dev server)
VITE_API_BASE_URL=http://localhost:8000
