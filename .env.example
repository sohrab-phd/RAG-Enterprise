# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1

# PostgreSQL (pgvector image)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_password
POSTGRES_DB=rag_enterprise
DATABASE_URL=postgresql+asyncpg://rag:rag_dev_password@localhost:5432/rag_enterprise

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Local upload binary storage (RC1.6)
FILE_STORAGE_ROOT=storage/uploads

# Frontend (Vite dev server)
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# LLM execution (RC2.6 / RC2.7) — LLM_BACKEND=local|api|mock
# V1 default is local (Ollama). Use mock for CI/tests; api for OpenAI-compatible.
# See docs/backend/OLLAMA.md for install, model pull, and selection.
# Legacy LLM_BACKEND=echo|http are remapped to mock|api with a startup warning.
# ---------------------------------------------------------------------------
LLM_BACKEND=local
LOCAL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL_KEY=auto   → discover via GET /api/tags (empty also means auto)
# LLM_MODEL_KEY=gemma4:e4b-it-qat  → must be installed or startup fails
LLM_MODEL_KEY=auto
LLM_TIMEOUT_SECONDS=60

# API mode (when LLM_BACKEND=api):
# API_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# LLM_MODEL_KEY=gpt-4o-mini

# Mock mode (tests / offline demos only — not recommended for production):
# LLM_BACKEND=mock
# MOCK_PROVIDER=echo

# ---------------------------------------------------------------------------
# Embeddings / retrieval — MUST match RC2.3–RC2.5 benchmark for production HTTP
# FastAPI, RetrievalService, Indexing, GenerationService, and the benchmark all
# use create_embedding_provider(settings) — no silent deterministic fallback.
# Use EMBEDDING_BACKEND=deterministic only in CI / unit tests (explicit).
# ---------------------------------------------------------------------------
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL_KEY=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
RETRIEVAL_DEFAULT_TOP_K=8
GENERATION_MIN_EVIDENCE_SCORE=0.25
